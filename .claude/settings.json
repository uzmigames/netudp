{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash F:/Node/netudp/.claude/hooks/on-compact-reinject.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash F:/Node/netudp/.claude/hooks/resume-from-handoff.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash F:/Node/netudp/.claude/hooks/check-context-and-handoff.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash F:/Node/netudp/.claude/hooks/enforce-no-deferred.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash F:/Node/netudp/.claude/hooks/enforce-no-shortcuts.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash F:/Node/netudp/.claude/hooks/enforce-mcp-for-tasks.sh"
          }
        ]
      }
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  }
}
